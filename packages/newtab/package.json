    "@mui/material": "^7.3.7",
    "@tanstack/react-form": "^1.28.0",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-query-devtools": "^5.91.2",
    "@toolpad/core": "^0.16.0",
    "@tsparticles/engine": "^3.9.1",
